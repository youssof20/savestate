; Engine configuration file.
config_version=5

[application]

config/name="SaveState Starter Sample"
config/description="Minimal scene: move, gold, Save/Load. See README in this folder."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

SaveManager="*res://addons/savestate/save_manager.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/savestate/plugin.cfg")
